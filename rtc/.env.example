# Copy this file to rtc/.env and replace every example value before deployment.
# This .env is independent from the top-level .env (text backend). It only
# configures the MatrixRTC backend (LiveKit SFU + lk-jwt-service).

# Public hostname for the MatrixRTC backend. Must be a DNS-only (no CDN proxy)
# record so that WebRTC UDP media and the LiveKit signaling websocket can
# reach this host's IP directly. See README.md "MatrixRTC backend" section.
RTC_HOST=rtc.example.com

# Matrix server_name of the homeserver this LiveKit backend serves. Only
# users on this homeserver are granted "full access" (can start/host calls);
# users from other (federated) homeservers can only join.
SERVER_NAME=example.com

# Public IPv4 address of this VPS. LiveKit runs with network_mode: host, so
# it cannot rely on container-network auto-detection; the address is baked
# into livekit.yaml by generate-livekit-config.sh.
NODE_IP=203.0.113.10

# Shared API key/secret pair between LiveKit and lk-jwt-service. Any value
# works as long as both services agree; generate a long random secret for
# LIVEKIT_SECRET before deploying.
LIVEKIT_KEY=selfmatrix
LIVEKIT_SECRET=replace-with-random
